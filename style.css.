/* ---------------------- */
/* General Styles */
/* ---------------------- */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  font-family: 'Inter', sans-serif;
}

body {
  background-color: #f5f5f5;
  color: #333;
}

a {
  text-decoration: none;
}

button {
  cursor: pointer;
  border: none;
}

/* ---------------------- */
/* Hero Section */
/* ---------------------- */
.hero {
  height: 100vh;
  background: url('/images/ambient-led.jpg') center/cover no-repeat;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  position: relative;
  color: white;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.45); /* dark overlay for readability */
}

.hero-content {
  position: relative;
  z-index: 1;
  max-width: 800px;
  padding: 20px;
}

.hero-content img {
  width: 180px;
  margin-bottom: 20px;
}

.hero h1 {
  font-size: 3rem;
  margin-bottom: 15px;
  font-weight: 700;
  text-shadow: 1px 1px 5px rgba(0,0,0,0.5);
}

.hero p {
  font-size: 1.2rem;
  margin-bottom: 20px;
  text-shadow: 1px 1px 3px rgba(0,0,0,0.4);
}

.btn-primary {
  background: linear-gradient(90deg, #FFD700, #FFA500);
  color: #000;
  padding: 12px 30px;
  border-radius: 8px;
  font-size: 1.1rem;
  font-weight: 600;
  transition: 0.3s;
  box-shadow: 0 5px 15px rgba(0,0,0,0.2);
}

.btn-primary:hover {
  opacity: 0.85;
  transform: translateY(-2px);
}

/* ---------------------- */
/* Calculator Section */
/* ---------------------- */
#calculator {
  padding: 60px 20px;
  background: #f5f5f5;
}

.calculator-container {
  max-width: 800px;
  margin: auto;
  background: #fff;
  border-radius: 12px;
  padding: 40px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

.calculator-container h2 {
  text-align: center;
  font-size: 2.5rem;
  margin-bottom: 30px;
}

form {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

form label {
  display: block;
  font-weight: 600;
  margin-bottom: 6px;
}

input, select {
  width: 100%;
  padding: 10px;
  border-radius: 6px;
  border: 1px solid #ccc;
  font-size: 1rem;
}

input[type="range"] {
  width: 100%;
}

form button {
  grid-column: span 2;
  justify-self: center;
}

#results {
  margin-top: 30px;
  text-align: center;
  font-size: 1.2rem;
}

#results span {
  color: #FFA500;
  font-weight: 700;
}

/* ---------------------- */
/* Responsive Design */
/* ---------------------- */
@media(max-width: 768px) {
  form { grid-template-columns: 1fr; }
  .hero h1 { font-size: 2.2rem; }
  .hero p { font-size: 1rem; }
}
